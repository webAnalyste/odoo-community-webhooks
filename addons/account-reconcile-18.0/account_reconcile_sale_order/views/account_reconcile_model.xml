<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_account_reconcile_model_form" model="ir.ui.view">
        <field name="model">account.reconcile.model</field>
        <field name="inherit_id" ref="account.view_account_reconcile_model_form" />
        <field name="arch" type="xml">
            <group id="conditions_tab_group" position="after">
                <group
                    name="account_reconcile_sale_order"
                    invisible="rule_type != 'sale_order_matching'"
                >
                    <field
                        name="sale_order_matching_payment_method_ids"
                        widget="many2many_tags"
                    />
                    <field name="sale_order_matching_token_match" />
                    <field
                        name="sale_order_matching_token_length"
                        invisible="not sale_order_matching_token_match"
                    />
                </group>
            </group>
            <xpath expr="//field[@name='line_ids']/.." position="attributes">
                <attribute
                    name="invisible"
                    separator=" or "
                    add="rule_type == 'sale_order_matching'"
                />
            </xpath>
        </field>
    </record>
</odoo>
