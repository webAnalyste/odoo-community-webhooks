<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="account_move_line_reconcile_list_view" model="ir.ui.view">
        <field name="name">account.move.line.reconcile.list</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_tree" />
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <header>
                    <button
                        name="action_reconcile_manually"
                        type="object"
                        string="Reconcile"
                        groups="account.group_account_user"
                        data-hotkey="r"
                    />
                </header>
            </xpath>
        </field>
    </record>
    <record id="account_move_line_reconcile_act_window" model="ir.actions.act_window">
        <field name="name">Reconcile</field>
        <field name="res_model">account.move.line</field>
        <field name="view_mode">list</field>
        <field
            name="domain"
        >[('display_type', 'not in', ('line_section', 'line_note')), ('account_id.reconcile', '=', True), ('parent_state', '=', 'posted'), ('full_reconcile_id', '=', False)]</field>
        <field
            name="context"
        >{'journal_type': 'general', 'search_default_unreconciled': True, 'search_default_group_by_account': True, 'search_default_group_by_partner': True, 'expand': True}</field>
        <field name="search_view_id" ref="account.view_account_move_line_filter" />
        <field name="view_id" ref="account_move_line_reconcile_list_view" />
    </record>

    <record model="ir.ui.menu" id="account_move_line_reconcile_menu">
        <field name="name">Reconcile</field>
        <field name="parent_id" ref="account.menu_finance_entries" />
        <field name="action" ref="account_move_line_reconcile_act_window" />
        <field name="sequence" eval="140" />
    </record>
    <!-- Inactive the menu from account_reconcile_oca module to avoid confusion with two similar menus -->
    <record
        model="ir.ui.menu"
        id="account_reconcile_oca.account_account_reconcile_menu"
    >
        <field name="active" eval="False" />
    </record>
</odoo>
