<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Ajout du champ "Contact client" dans le formulaire opportunité CRM -->
    <record id="crm_lead_form_x_contact_id" model="ir.ui.view">
        <field name="name">crm.lead.form.x_contact_id</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='opportunity_partner']/field[@name='partner_id']" position="after">
                <field name="x_contact_id"
                       string="Contact client"
                       options="{'no_create': True}"
                       placeholder="Sélectionner un contact..."/>
                <field name="x_participants" string="Nombre de participants"/>
                <field name="x_date_debut" string="Date de début"/>
                <field name="x_date_fin" string="Date de fin"/>
                <field name="x_nb_heures" string="Nombre d'heures"/>
                <field name="x_stagiaires" string="Liste des stagiaires"
                       placeholder="Ex : Prénom1 Nom1, Prénom2 Nom2, ..."/>
                <field name="x_stagiaires_emails" string="Emails des stagiaires"
                       placeholder="Ex : email1@exemple.com, email2@exemple.com, ..."/>
            </xpath>
        </field>
    </record>
</odoo>
