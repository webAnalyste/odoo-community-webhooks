<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Ajout du champ "Contact client" dans le formulaire opportunité CRM -->
    <record id="crm_lead_form_x_contact_id" model="ir.ui.view">
        <field name="name">crm.lead.form.x_contact_id</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <label for="email_from" position="before">
                <field name="x_contact_id"
                       string="Contact client"
                       options="{'no_create': True, 'no_open': True}"
placeholder="Sélectionner un contact..."/>
            </label>
        </field>
    </record>
</odoo>
