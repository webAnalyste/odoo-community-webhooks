<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- RECHERCHE -->
    <record id="webhook_log_view_search" model="ir.ui.view">
        <field name="name">webhook.log.search</field>
        <field name="model">webhook.log</field>
        <field name="arch" type="xml">
            <search string="Rechercher dans les logs">
                <field name="endpoint_id" string="Endpoint"/>
                <field name="action" string="Action"/>
                <filter name="filter_error" string="Erreurs" domain="[('success', '=', False)]"/>
                <filter name="filter_success" string="Succès" domain="[('success', '=', True)]"/>
                <separator/>
                <filter name="filter_create" string="Création" domain="[('action', '=', 'create')]"/>
                <filter name="filter_write" string="Modification" domain="[('action', '=', 'write')]"/>
                <filter name="filter_unlink" string="Suppression" domain="[('action', '=', 'unlink')]"/>
                <separator/>
                <filter name="filter_today" string="Aujourd'hui"
                        domain="[('create_date', '&gt;=', datetime.datetime.now().strftime('%Y-%m-%d 00:00:00'))]"/>
                <group expand="0" string="Grouper par">
                    <filter name="group_endpoint" string="Endpoint" context="{'group_by': 'endpoint_id'}"/>
                    <filter name="group_action" string="Action" context="{'group_by': 'action'}"/>
                    <filter name="group_success" string="Statut" context="{'group_by': 'success'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- LISTE -->
    <record id="webhook_log_view_tree" model="ir.ui.view">
        <field name="name">webhook.log.tree</field>
        <field name="model">webhook.log</field>
        <field name="arch" type="xml">
            <list string="Historique webhooks"
                  decoration-danger="not success"
                  decoration-success="success">
                <field name="create_date" string="Date"/>
                <field name="endpoint_id" string="Webhook"/>
                <field name="action"/>
                <field name="record_id" string="ID enreg."/>
                <field name="status_code" string="HTTP"/>
                <field name="success" string="Succès"/>
                <field name="retry_count" string="Tentatives" optional="show"/>
                <field name="response" string="Réponse" optional="show"/>
                <button name="action_retry" type="object" string="Rejouer"
                        icon="fa-refresh"
                        invisible="success"/>
            </list>
        </field>
    </record>

    <!-- FORMULAIRE -->
    <record id="webhook_log_view_form" model="ir.ui.view">
        <field name="name">webhook.log.form</field>
        <field name="model">webhook.log</field>
        <field name="arch" type="xml">
            <form string="Log webhook" create="false">
                <header>
                    <button name="action_retry" type="object"
                            string="Rejouer ce webhook"
                            class="btn-primary"
                            invisible="success"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="create_date" string="Date"/>
                            <field name="endpoint_id"/>
                            <field name="action"/>
                            <field name="record_id"/>
                        </group>
                        <group>
                            <field name="status_code"/>
                            <field name="success"/>
                            <field name="retry_count"/>
                        </group>
                    </group>
                    <group string="Payload envoyé">
                        <field name="payload" widget="code" nolabel="1"/>
                    </group>
                    <group string="Réponse reçue">
                        <field name="response" widget="code" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION FENÊTRE -->
    <record id="action_webhook_log" model="ir.actions.act_window">
        <field name="name">Historique webhooks</field>
        <field name="res_model">webhook.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="webhook_log_view_search"/>
        <field name="context">{'search_default_filter_error': 0}</field>
    </record>

</odoo>
