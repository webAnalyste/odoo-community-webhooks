<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LISTE -->
    <record id="webhook_endpoint_view_tree" model="ir.ui.view">
        <field name="name">webhook.endpoint.tree</field>
        <field name="model">webhook.endpoint</field>
        <field name="arch" type="xml">
            <list string="Webhooks" decoration-muted="not active">
                <field name="name"/>
                <field name="odoo_model"/>
                <field name="crud_action"/>
                <field name="http_method"/>
                <field name="url"/>
                <field name="log_count" string="Appels"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- FORMULAIRE -->
    <record id="webhook_endpoint_view_form" model="ir.ui.view">
        <field name="name">webhook.endpoint.form</field>
        <field name="model">webhook.endpoint</field>
        <field name="arch" type="xml">
            <form string="Webhook Endpoint">
                <header>
                    <button name="action_test"
                            type="object"
                            string="Tester le webhook"
                            class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_logs"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-history">
                            <field name="log_count" widget="statinfo" string="Appels"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Inactif" bg_color="bg-danger"
                            invisible="active"/>
                    <field name="active" invisible="1"/>
                    <group>
                        <group string="Identification">
                            <field name="name" placeholder="Ex: Nouveau contact → Make"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group string="Déclencheur">
                            <field name="odoo_model"/>
                            <field name="crud_action"/>
                        </group>
                    </group>
                    <group>
                        <group string="Destination">
                            <field name="url" placeholder="https://hook.make.com/..."/>
                            <field name="http_method"/>
                            <field name="timeout"/>
                        </group>
                        <group string="Sécurité">
                            <field name="secret_token" password="True"
                                   placeholder="Optionnel — envoyé dans Authorization: Bearer &lt;token&gt;"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Paramètres CRM"
                              invisible="odoo_model != 'crm.lead'">
                            <group string="Filtres de déclenchement">
                                <field name="crm_stage_domain" invisible="1"/>
                                <field name="crm_stage_ids" widget="many2many_tags"
                                       placeholder="Toutes les étapes"
                                       domain="crm_stage_domain"/>
                                <field name="crm_team_ids" widget="many2many_tags"
                                       placeholder="Toutes les équipes"/>
                            </group>
                            <group string="Blocs de données envoyés dans le payload">
                                <field name="crm_include_description"/>
                                <field name="crm_include_x_contact"/>
                                <field name="crm_include_participants"/>
                                <field name="crm_include_product_codes"/>
                                <field name="crm_include_orders"/>
                                <field name="crm_include_pdf" invisible="not crm_include_orders"/>
                                <field name="crm_include_contacts"/>
                            </group>
                        </page>
                        <page string="Historique des appels">
                            <field name="log_ids" readonly="1">
                                <list decoration-danger="not success"
                                      decoration-success="success">
                                    <field name="create_date" string="Date"/>
                                    <field name="action"/>
                                    <field name="record_id" string="ID"/>
                                    <field name="status_code" string="HTTP"/>
                                    <field name="success" string="OK"/>
                                    <field name="response" string="Réponse"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- RECHERCHE -->
    <record id="webhook_endpoint_view_search" model="ir.ui.view">
        <field name="name">webhook.endpoint.search</field>
        <field name="model">webhook.endpoint</field>
        <field name="arch" type="xml">
            <search string="Rechercher un webhook">
                <field name="name" string="Nom"/>
                <field name="url" string="URL"/>
                <filter name="filter_active" string="Actifs" domain="[('active', '=', True)]"/>
                <filter name="filter_inactive" string="Inactifs" domain="[('active', '=', False)]"/>
                <separator/>
                <filter name="filter_partner" string="Contact" domain="[('odoo_model', '=', 'res.partner')]"/>
                <filter name="filter_invoice" string="Facture" domain="[('odoo_model', '=', 'account.move')]"/>
                <filter name="filter_sale" string="Commande" domain="[('odoo_model', '=', 'sale.order')]"/>
                <filter name="filter_crm" string="Opportunité" domain="[('odoo_model', '=', 'crm.lead')]"/>
                <separator/>
                <filter name="filter_create" string="Création" domain="[('crud_action', '=', 'create')]"/>
                <filter name="filter_write" string="Modification" domain="[('crud_action', '=', 'write')]"/>
                <filter name="filter_unlink" string="Suppression" domain="[('crud_action', '=', 'unlink')]"/>
                <group expand="0" string="Grouper par">
                    <filter name="group_model" string="Modèle" context="{'group_by': 'odoo_model'}"/>
                    <filter name="group_action" string="Action" context="{'group_by': 'crud_action'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ACTION FENÊTRE -->
    <record id="action_webhook_endpoint" model="ir.actions.act_window">
        <field name="name">Webhooks</field>
        <field name="res_model">webhook.endpoint</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="webhook_endpoint_view_search"/>
        <field name="context">{'search_default_filter_active': 1}</field>
    </record>

</odoo>
